<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ================= LOCAL (가독성 로그) ================= -->

    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [traceId=%X{traceId:-}] [jobId=%X{jobId:-}] [userId=%X{userId:-}] %-5level %logger{36} - %msg%n%ex"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ================= JSON 로그 (운영용) ================= -->

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">

            <providers>

                <!-- timestamp -->
                <timestamp>
                    <fieldName>timestamp</fieldName>
                    <pattern>yyyy-MM-dd HH:mm:ss.SSS</pattern>
                </timestamp>

                <!-- 기본 필드 -->
                <threadName fieldName="thread"/>
                <logLevel fieldName="level"/>
                <loggerName fieldName="logger"/>

                <!-- message -->
                <message/>

                <!-- MDC -->
                <mdc/>

                <!-- stacktrace -->
                <stackTrace>
                    <fieldName>stacktrace</fieldName>
                </stackTrace>

            </providers>

        </encoder>
    </appender>

    <!-- ================= PROFILE ================= -->

    <!-- 로컬 -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- dev / prod -->
    <springProfile name="dev,prod">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ================= LOGGER LEVEL ================= -->

    <logger name="sopt.comfit" level="DEBUG"/>
    <logger name="sopt.comfit.report" level="DEBUG"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>

</configuration>